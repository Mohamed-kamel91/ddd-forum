{
  "tabWidth": 2,
  "useTabs": false,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "printWidth": 70,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": [
        "**/*.test.{js,jsx,ts,tsx}",
        "**/*.spec.{js,jsx,ts,tsx}",
        "**/*.unit.{js,jsx,ts,tsx}",
        "**/*.infra.{js,jsx,ts,tsx}",
        "**/*.e2e.{js,jsx,ts,tsx}"
      ],
      "options": {
        "printWidth": 80
      }
    }
  ]
}
