{
  "name": "@dddforum/backend",
  "description": "A forum web application for developers to share ideas, thoughts, and experiences about Domain-Driven Design (DDD).",
  "version": "1.0.0",
  "author": "Mohamed Kamel",
  "license": "ISC",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "tsc",
    "lint": "eslint . --ext .ts",
    "start": "node dist/index.js",
    "start:dev": "yarn db:migrate && yarn db:generate && nodemon",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:seed": "yarn db:migrate && yarn db:seed",
    "db:sync": "yarn db:migrate && yarn db:generate",
    "db:setup": "yarn db:migrate && yarn db:generate && yarn db:seed",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:reset:seed": "prisma migrate reset && yarn db:seed",
    "db:studio": "prisma studio",
    "prettier-format": "run-script-os",
    "prettier-format:win32": "prettier --config .prettierrc \"./src/**/*.ts\" --write",
    "prettier-format:darwin:linux": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "prettier-format:default": "prettier --config .prettierrc 'src/**/*.ts' --write",
    "prettier-watch": "run-script-os",
    "prettier-watch:win32": "onchange \"src/**/*.ts\" -- prettier --write {{changed}}",
    "prettier-watch:darwin:linux": "onchange 'src/**/*.ts' -- prettier --write {{changed}}",
    "prettier-watch:default": "onchange 'src/**/*.ts' -- prettier --write {{changed}}",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:dev": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watchAll",
    "test:e2e": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --verbose tests/e2e/ --runInBand"
  },
  "husky": {
    "hooks": {
      "pre-commit": "yarn test && yarn prettier-format && yarn lint"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@dddforum/shared": "*",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/supertest": "^6.0.3",
    "nodemon": "^3.1.11",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2"
  }
}
