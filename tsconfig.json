{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["ES2022"],
    "types": ["node", "jest"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "paths": {
      "@dddforum/backend/*": ["packages/backend/src/*"],
      "@dddforum/frontend/*": ["packages/frontend/src/*"],
      "@dddforum/shared/*": ["packages/shared/src/*"]
    }
  }
}
