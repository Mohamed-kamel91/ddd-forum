{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "lib": ["ES2022"],
    "types": ["node", "jest"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@dddforum/backend/*": ["./packages/backend/*"],
      "@dddforum/frontend/*": ["./packages/frontend/*"],
      "@dddforum/shared/*": ["./packages/shared/*"]
    }
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.infra.ts",
    "**/*.test.ts",
    "**/*.e2e.ts"
  ]
}
