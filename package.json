{
  "name": "dddforum",
  "private": true,
  "version": "1.0.0",
  "description": "A forum web application for developers to share ideas, thoughts, and experiences about Domain-Driven Design (DDD).",
  "license": "ISC",
  "author": "Mohamed Kamel",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "yarn workspaces run clean",
    "start": "yarn workspace @dddforum/backend start",
    "build": "yarn build:shared && yarn build:back && yarn build:front",
    "build:shared": "yarn workspace @dddforum/shared build",
    "build:front": "yarn workspace @dddforum/frontend build",
    "build:back": "yarn workspace @dddforum/backend build",
    "lint": "yarn workspaces run lint",
    "start:dev:front": "yarn workspace @dddforum/frontend start:dev",
    "start:dev:back": "yarn workspace @dddforum/backend start:dev",
    "test:e2e:front": "yarn workspace @dddforum/frontend test:e2e",
    "test:unit:back": "yarn workspace @dddforum/backend test:unit",
    "test:infra:back": "yarn workspace @dddforum/backend test:infra",
    "test:e2e:back": "yarn workspace @dddforum/backend test:e2e"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.13.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-cucumber": "^4.5.0",
    "onchange": "^7.1.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "run-script-os": "^1.1.6",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0"
  }
}
